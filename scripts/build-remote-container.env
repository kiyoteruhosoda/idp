# build-remote-container.sh の設定（KEY=VALUE 形式・コマンド実行不要）。
# スクリプトと同じ場所に置く。行頭コメント（#）と空行は無視され、値の前後空白は除去される。
# ※ deploy.sh / Compose が読む「デプロイ用 .env（秘密情報）」とは別物。
#
# 値の中の {PROJECT} は下の PROJECT の値へ展開される（プロジェクト名は 1 度だけ書けばよい）。

# プロジェクト名（このファイル内の {PROJECT} へ展開される）
PROJECT=idp
# ビルドを行う dev コンテナ名
IDP_DEV_CONTAINER=ubuntu-dev
# コンテナ内でビルドを実行するユーザー
IDP_DEV_USER=sshuser
# コンテナ内のリポジトリ working dir（scripts/build.sh がある場所）
IDP_DEV_WORKDIR=/work/project/{PROJECT}
# ホストから見えるビルド済み dist/ の絶対パス（必須）
IDP_DIST_DIR=/var/services/homes/kyon/ubuntu-ssh/work/project/{PROJECT}/dist
