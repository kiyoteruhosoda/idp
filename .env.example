# アプリ設定（環境変数 > DB > 既定値）。ローカル開発ではこのファイルを `.env` にコピーして使う。
ISSUER=http://localhost:8080
BIND_ADDR=0.0.0.0:8080
DATABASE_URL=mysql://idp:idp@127.0.0.1:3306/idp
DB_MAX_CONNECTIONS=10

# ログ: json | pretty
LOG_FORMAT=pretty
RUST_LOG=info,idp=debug

# TTL（秒）。未設定時は既定値（AuthSession 600 / code 60 / SSO idle 28800 / SSO absolute 86400 /
# access 900 / id_token 3600 / clock skew 60）。
# AUTH_SESSION_TTL_SECS=600
# AUTHORIZATION_CODE_TTL_SECS=60
# SSO_IDLE_TTL_SECS=28800
# SSO_ABSOLUTE_TTL_SECS=86400
# ACCESS_TOKEN_TTL_SECS=900
# ID_TOKEN_TTL_SECS=3600
# CLOCK_SKEW_SECS=60
