# .env.example — 秘密情報・環境設定の一元管理テンプレート。
#
# 使い方:
#   - ローカル/本番とも `scripts/init.sh` が本ファイルを基に秘密値を生成して `.env` を作る。
#   - 手動で使う場合はこのファイルを `.env` にコピーし、下記 CHANGE-ME を実値へ置き換える。
#   - `.env` は .gitignore 済み（コミットしない）。本ファイル（.env.example）のみコミットする。
#   - Docker Compose は同ディレクトリの `.env` を自動読込する。アプリ/テストは dotenvy 経由で読む。
#     （設定取得は必ず config モジュール経由。生の env 直接参照は禁止。）

# ---- OIDC / HTTP ----
ISSUER=http://localhost:8080
# ホスト側で公開するポート（Compose のリバースプロキシ。単一オリジンで web/api を振り分ける）。
WEB_PORT=8080
DB_MAX_CONNECTIONS=10

# ---- デプロイ用イメージ（ソースとデプロイ先が別ホストのとき） ----
# ビルド済みイメージの名前解決に使う（scripts/build.sh と docker-compose.deploy.yml で共通）。
# イメージ名は ${IMAGE_PREFIX}/{api,web,migrate}:${IMAGE_TAG}。
#   - レジストリ配布: IMAGE_PREFIX にレジストリホストを含める（例: registry.example.com/idp）。
#     ソース側で `./scripts/build.sh --docker --push`、デプロイ先で init.sh/deploy.sh が pull する。
#   - tar 配布: IMAGE_PREFIX は既定 idp のまま。ソース側で `--save DIR`→転送→`docker load -i`。
IMAGE_PREFIX=idp
IMAGE_TAG=latest

# ---- web サービス（ADR-0007。HTML 画面＋API クライアント。DB 非依存） ----
# web が listen するアドレス。
# WEB_BIND_ADDR=0.0.0.0:8081
# web から api への到達先ベース URL（末尾スラッシュ無し）。単一オリジン構成ではプロキシ内部アドレス。
# API_BASE_URL=http://localhost:8080

# ---- MariaDB（Compose の mariadb サービスと共有） ----
MARIADB_DATABASE=idp
MARIADB_USER=idp
# CHANGE-ME: DB パスワード（idp ユーザー / root）。init.sh が乱数生成する。
MARIADB_PASSWORD=CHANGE-ME
MARIADB_ROOT_PASSWORD=CHANGE-ME
# 開発 Compose でホスト側に公開する MariaDB の bind 先とポート（既定は loopback のみ）。
# デプロイ Compose は既定で MariaDB をホスト公開しない。保守時だけ docker-compose.db-debug.yml を重ねる。
MARIADB_BIND_HOST=127.0.0.1
MARIADB_PORT=3306

# ---- DATABASE_URL ----
# ホストから実行する sqlx-cli / cargo run 用（Compose 内の web は mariadb サービス名で別途解決）。
# ${MARIADB_PASSWORD} は展開されないため、init.sh が実値で書き出す（手動時は置換すること）。
DATABASE_URL=mysql://idp:CHANGE-ME@127.0.0.1:3306/idp
# 統合テスト用（tests/ は未設定時スキップ）。開発用 DB を指す。
TEST_DATABASE_URL=mysql://idp:CHANGE-ME@127.0.0.1:3306/idp

# ---- 署名鍵の暗号化キー（base64、32 バイト） ----
# CHANGE-ME: 本番では必須。`openssl rand -base64 32` で生成（init.sh が自動生成）。
KEY_ENCRYPTION_KEY=CHANGE-ME

# ---- 内部サービス認証トークン（ADR-0007 §5） ----
# CHANGE-ME: web→api の /internal/* 呼び出しを保護する共有シークレット（api・web で同値）。
# init.sh が `openssl rand -hex 32` で生成する。Compose は本値を必須とする（api・web 双方へ注入）。
INTERNAL_SERVICE_TOKEN=CHANGE-ME
# CHANGE-ME: api/web 共有の CSRF HMAC 鍵（base64、32 バイト）。init.sh が生成する。
CSRF_SECRET=CHANGE-ME

# ---- ログ ----
# json | pretty
LOG_FORMAT=pretty
RUST_LOG=info,idp=debug

# ---- Cookie ----
# 未設定なら issuer が https のとき自動で Secure。http のローカルでは false のままでよい。
# COOKIE_SECURE=false

# ---- Redis（任意。profiles: optional。スケール時のみ） ----
REDIS_PASSWORD=redis
REDIS_PORT=6379

# ---- TTL（秒）。未設定時は既定値 ----
# AUTH_SESSION_TTL_SECS=600
# AUTHORIZATION_CODE_TTL_SECS=60
# SSO_IDLE_TTL_SECS=28800
# SSO_ABSOLUTE_TTL_SECS=86400
# ACCESS_TOKEN_TTL_SECS=900
# ID_TOKEN_TTL_SECS=3600
# REFRESH_TOKEN_TTL_SECS=2592000
# CLOCK_SKEW_SECS=60
# INVITATION_TTL_SECS=604800
# PASSWORD_RESET_TTL_SECS=3600
# EMAIL_VERIFICATION_TTL_SECS=86400
# TENANT_CACHE_TTL_SECS=60
# PERMISSION_CACHE_TTL_SECS=60

# ---- 署名鍵ローテーション（K2） ----
# not_after のこの日数前に次期鍵を自動生成して旧鍵を退役させる（既定 30 日）。
# KEY_ROTATION_LEAD_DAYS=30

# ---- SSL アクセラレーター / リバースプロキシ対応（S1） ----
# リバースプロキシが付与する X-Forwarded-For を信頼するか（既定 false）。
# true にすると X-Forwarded-For の先頭値を実 IP として監査ログ・レート制限に使う。
# TRUST_FORWARDED_HEADERS=false
# HSTS max-age（秒）。0 = HSTS ヘッダを付与しない（既定 0）。
# HTTPS プロキシ配下で運用する場合は例: HSTS_MAX_AGE=31536000
# HSTS_MAX_AGE=0

# ---- 公開 web URL ----
# 招待/パスワードリセット等で利用者に送る web 画面のベース URL。未設定時は ISSUER。
# PUBLIC_WEB_BASE_URL=http://localhost:8080
