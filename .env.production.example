# .env.production.example — 同一ホストに stg/prod を置くための production 用サンプル。
#
# 使い方:
#   1. production 用ディレクトリへ dist/ を配置する
#   2. cp .env.production.example .env
#   3. CHANGE-ME を実値に置換し、外からアクセスするホスト名/IPに合わせて ISSUER を変更する
#   4. IMAGE_TAG=prod ./scripts/build.sh dist-prod のように、prod 用タグで作った dist と組み合わせる
#
# 同一ホスト運用では WEB_PORT を stg と必ず分ける。コンテナ内ポートは常に 8080、
# 外部公開ポートだけが WEB_PORT で変わる（例: http://<host>:8080）。

# ---- OIDC / HTTP（外部から http で接続する production） ----
ISSUER=http://localhost:8080
PUBLIC_WEB_BASE_URL=http://localhost:8080
WEB_PORT=8080
DB_MAX_CONNECTIONS=20

# ---- デプロイ用イメージ（stg とタグを分け、同一ホストで latest を取り合わない） ----
IMAGE_PREFIX=idp
IMAGE_TAG=prod

# ---- MariaDB ----
MARIADB_DATABASE=idp
MARIADB_USER=idp
MARIADB_PASSWORD=CHANGE-ME
MARIADB_ROOT_PASSWORD=CHANGE-ME
# デプロイ Compose は DB をホスト公開しない。保守用 override を使う場合も stg と衝突しない値にする。
MARIADB_BIND_HOST=127.0.0.1
MARIADB_PORT=3306

DATABASE_URL=mysql://idp:CHANGE-ME@127.0.0.1:3306/idp
TEST_DATABASE_URL=mysql://idp:CHANGE-ME@127.0.0.1:3306/idp

KEY_ENCRYPTION_KEY=CHANGE-ME
INTERNAL_SERVICE_TOKEN=CHANGE-ME
CSRF_SECRET=CHANGE-ME

LOG_FORMAT=json
RUST_LOG=info,idp=info
# 外部 http 直結なら false。HTTPS 終端プロキシ配下にしたら true/未設定 + HSTS を検討する。
COOKIE_SECURE=false
TRUST_FORWARDED_HEADERS=false
HSTS_MAX_AGE=0
