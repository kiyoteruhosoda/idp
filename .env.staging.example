# .env.staging.example — 同一ホストに stg/prod を置くための staging 用サンプル。
#
# 使い方:
#   1. staging 用ディレクトリへ dist/ を配置する
#   2. cp .env.staging.example .env
#   3. CHANGE-ME を実値に置換し、外からアクセスするホスト名/IPに合わせて ISSUER を変更する
#   4. IMAGE_TAG=stg ./scripts/build.sh dist-stg のように、stg 用タグで作った dist と組み合わせる
# 同一ホスト運用では WEB_PORT を prod と必ず分ける。コンテナ内ポートは常に 8080、
# 外部公開ポートだけが WEB_PORT で変わる（例: http://<host>:8061）。

# ---- OIDC / HTTP（外部から http で接続する staging） ----
ISSUER=http://localhost:8061
PUBLIC_WEB_BASE_URL=http://localhost:8061
# Docker の公開ポートを NAS の全インターフェースへ出さず、ローカル待受に限定する。
WEB_BIND_HOST=127.0.0.1
WEB_PORT=8061
DB_MAX_CONNECTIONS=10

# ---- デプロイ用イメージ（prod とタグを分け、同一ホストで latest を取り合わない） ----
IMAGE_PREFIX=idp
IMAGE_TAG=stg
COMPOSE_PROJECT_NAME=idp-stg

# ---- MariaDB ----
MARIADB_DATABASE=idp
MARIADB_USER=idp
MARIADB_PASSWORD=CHANGE-ME
MARIADB_ROOT_PASSWORD=CHANGE-ME
# デプロイ Compose は DB をホスト公開しない。保守用 override を使う場合も prod と衝突しない値にする。
MARIADB_BIND_HOST=127.0.0.1
MARIADB_PORT=3307

DATABASE_URL=mysql://idp:CHANGE-ME@127.0.0.1:3307/idp
TEST_DATABASE_URL=mysql://idp:CHANGE-ME@127.0.0.1:3307/idp

KEY_ENCRYPTION_KEY=CHANGE-ME
INTERNAL_SERVICE_TOKEN=CHANGE-ME
CSRF_SECRET=CHANGE-ME

LOG_FORMAT=pretty
RUST_LOG=info,idp=debug
# 外部 http 接続なら false のまま。HTTPS 終端プロキシ配下にしたら true/未設定運用を検討する。
COOKIE_SECURE=false
TRUST_FORWARDED_HEADERS=false
HSTS_MAX_AGE=0

# deploy.sh が migration 後に自動設定する。/ から root 管理ログインへ誘導するために使用。
ROOT_TENANT_ID=
